{
  "name": "itpassion",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "npm run env:check -- development",
    "dev": "next dev",
    "prebuild": "npm run env:check -- production",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "env:check": "node scripts/check-env.mjs",
    "env:pull": "npx vercel env pull .env.local --yes",
    "vercel:link": "npx vercel link --yes --project itpassion-mvp --scope appmanfredonia-8899s-projects",
    "env:bootstrap": "npm run vercel:link && npm run env:pull && npm run env:check"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.103.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
